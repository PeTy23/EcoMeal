@page "/business/create"
@page "/business/edit/{Id:guid}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "BusinessManager, Admin")]

@using EcoMeal.Database.Entities
@using EcoMeal.Database.Entities.Enums
@using EcoMeal.Services.interfaces
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

@rendermode InteractiveServer
@inject IBusinessService BusinessService
@inject IUserService UserService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider

<h3>@(IsEditMode ? "Edit Business" : "Create Business")</h3>

@if (loading)
{
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
}
else
{
    <EditForm Model="@model" OnValidSubmit="Submit" FormName="businessForm">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" />

        <div class="mb-3">
            <label for="name" class="form-label">Name</label>
            <InputText id="name" class="form-control" @bind-Value="model.Name" />
        </div>
        <div class="mb-3">
            <label for="Description" class="form-label">Description</label>
            <InputText id="Description" class="form-control" @bind-Value="model.Description" />
        </div>
        <div class="mb-3">
            <label for="Address" class="form-label">Address</label>
            <InputText id="Address" class="form-control" @bind-Value="model.Address" />
        </div>
        <div class="mb-3">
            <label for="ImageUrl" class="form-label">ImageUrl</label>
            <InputText id="ImageUrl" class="form-control" @bind-Value="model.ImageUrl" />
        </div>
        <div class="mb-3">
            <label for="BusinessType" class="form-label">BusinessType</label>
            <InputSelect id="businessType" class="form-select" @bind-Value="model.BusinessType">
                @foreach (var type in Enum.GetValues<BusinessTypeEnum>())
                {
                    <option value="@type">@type</option>
                }
            </InputSelect>
        </div>

        @* Secțiunea vizibilă DOAR pentru Admin *@
        @if (isAdmin)
        {
            <div class="mb-4 p-3 bg-light border rounded">
                <label for="ManagerId" class="form-label fw-bold text-danger">Assign to Business Manager (Admin Only)</label>
                <InputSelect id="ManagerId" class="form-select" @bind-Value="model.ManagerId">
                    <option value="">-- Select a Manager --</option>
                    @foreach (var manager in availableManagers)
                    {
                        <option value="@manager.Id">@manager.FullName (@manager.Email)</option>
                    }
                </InputSelect>
                @if (showAdminManagerError)
                {
                    <span class="text-danger small">Please select a manager for this business.</span>
                }
            </div>
        }

        <button type="submit" class="btn btn-primary">@(IsEditMode ? "Save" : "Create")</button>

        @if (IsEditMode)
        {
            <button type="button" class="btn btn-danger ms-2" @onclick="DeleteBusiness">Delete</button>
        }
    </EditForm>
}

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private bool IsEditMode => Id.HasValue;
    private bool loading = true;
    private BusinessFormModel model = new();

    // Variabile noi pentru logica de Admin
    private bool isAdmin = false;
    private List<ApplicationUser> availableManagers = new();
    private bool showAdminManagerError = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        isAdmin = user.IsInRole("Admin");

        // Dacă e admin, încărcăm toți managerii din baza de date pentru dropdown
        if (isAdmin)
        {
            availableManagers = await UserService.GetBusinessManagersAsync();
        }

        if (IsEditMode)
        {
            var business = await BusinessService.GetByIdAsync(Id!.Value);

            if (business is not null)
            {
                model = new BusinessFormModel
                {
                    Name = business.Name,
                    Description = business.Description,
                    Address = business.Address,
                    ImageUrl = business.ImageUrl,
                    BusinessType = (BusinessTypeEnum)business.BusinessTypeId,
                    ManagerId = business.ManagerId // Prepopulăm managerul existent la editare
                };
            }
        }

        loading = false;
    }

    private async Task Submit()
    {
        showAdminManagerError = false;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var currentUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (currentUserId == null) return;

        // Logica de validare a managerului
        string finalManagerId = string.Empty;

        if (isAdmin)
        {
            if (string.IsNullOrEmpty(model.ManagerId))
            {
                showAdminManagerError = true;
                return; // Oprim salvarea dacă Adminul nu a ales pe nimeni
            }
            finalManagerId = model.ManagerId;
        }
        else
        {
            // Dacă e BusinessManager, îi asignăm lui direct restaurantul
            finalManagerId = currentUserId;
        }

        var business = new Business
        {
            Id = Id ?? Guid.NewGuid(),
            Name = model.Name!,
            Description = model.Description!,
            Address = model.Address!,
            ImageUrl = model.ImageUrl!,
            BusinessTypeId = model.BusinessType,
            ManagerId = finalManagerId,
            type = null!,
            isApproved = isAdmin // Dacă Adminul îl creează, e aprobat instant! Dacă e manager, rămâne pe false.
        };

        if (IsEditMode)
        {
            await BusinessService.UpdateAsync(business);
        }
        else
        {
            await BusinessService.AddAsync(business);
        }

        // Redirecționare în funcție de rol
        if (isAdmin)
            NavigationManager.NavigateTo("/admin/businesses");
        else
            NavigationManager.NavigateTo("/"); // Vom schimba asta mai târziu spre dashboard-ul partenerului
    }

    private async Task DeleteBusiness()
    {
        if (Id.HasValue)
        {
            await BusinessService.DeleteAsync(Id.Value);
            NavigationManager.NavigateTo("/admin/businesses");
        }
    }

    private class BusinessFormModel
    {
        [Required(ErrorMessage = "Name is required.")]
        public string? Name { get; set; }

        [Required(ErrorMessage = "Description is required.")]
        public string? Description { get; set; }

        [Required(ErrorMessage = "Address is required.")]
        public string? Address { get; set; }

        public string? ImageUrl { get; set; }

        [Required]
        public BusinessTypeEnum BusinessType { get; set; }

        // Adăugăm ManagerId în model pentru a face bind cu Dropdown-ul
        public string? ManagerId { get; set; }
    }
}